1
00:00:00,000 --> 00:00:05,000
CMD: "move forward till you reach the wall"

2
00:00:05,890 --> 00:00:10,890
CMD: "then turn ninety degrees right"

3
00:00:09,080 --> 00:00:14,080
CMD: "send picture"

4
00:00:36,730 --> 00:00:41,730
Robot: "I see a few walls.  Which wall should I move to?"

5
00:00:36,740 --> 00:00:41,740
CMD: "the wall straight ahead"

6
00:01:13,900 --> 00:01:18,900
Robot: "I'm moving to the wall ahead of me.  Then what?"

7
00:01:15,170 --> 00:01:20,170
CMD: "turn right ninety degrees"

8
00:01:19,920 --> 00:01:24,920
CMD: "send picture"

9
00:01:28,760 --> 00:01:33,760
Robot: "executing..."

10
00:01:37,940 --> 00:01:42,940
Robot: "sent"

