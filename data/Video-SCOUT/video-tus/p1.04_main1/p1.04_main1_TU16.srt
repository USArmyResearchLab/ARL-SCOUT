1
00:00:00,000 --> 00:00:05,000
CMD: "go straight until you reach the wall"

2
00:00:04,720 --> 00:00:09,720
CMD: "stop"

3
00:00:05,820 --> 00:00:10,820
CMD: "turn left ninety degrees"

4
